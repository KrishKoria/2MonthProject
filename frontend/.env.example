# Optional frontend env template.
# Local development works without this file when the backend is running on
# http://127.0.0.1:8000 because Next.js proxies same-origin /api requests there.
#
# Copy to `.env.local` only when the backend lives on a different origin or when
# server-rendered requests should bypass the local proxy.

API_BASE_URL=http://127.0.0.1:8000

# Uncomment only if the browser should call the backend directly instead of
# going through the Next.js /api proxy. If you do this, make sure the backend's
# CORS_ALLOW_ORIGINS includes the frontend origin.
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
