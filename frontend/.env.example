# ─── Neon Postgres ────────────────────────────────────────────────────────────
# Pooled connection: used by runtime db client (drizzle-orm/neon-serverless Pool)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# Direct (unpooled) connection: used ONLY by drizzle-kit generate/migrate (DDL ops)
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# ─── Better Auth ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32-output

# Your app's base URL (no trailing slash)
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Create at: console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Microsoft / Azure Entra OAuth ────────────────────────────────────────────
# Create at: portal.azure.com → Azure Active Directory → App registrations
# Redirect URI: http://localhost:3000/api/auth/callback/microsoft
# tenantId in auth.ts is set to "common" to accept personal + org accounts
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# ─── Resend (invite emails) ───────────────────────────────────────────────────
# Get key at: resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key

# From address (must be verified in Resend dashboard under Domains)
MAIL_FROM=noreply@yourdomain.com

# ─── Existing vars (from Phase 0) ─────────────────────────────────────────────
# FastAPI backend URL — used by Next.js next.config.ts rewrite proxy
API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
