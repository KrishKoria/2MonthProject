OPENAI_API_KEY=sk-your-key-here
# DATA_DIR / CHROMA_DIR default to <project_root>/data. Override only if data
# lives elsewhere; use absolute paths (relative paths are CWD-sensitive).
# DATA_DIR=/abs/path/to/data
# CHROMA_DIR=/abs/path/to/data/chroma
LLM_MODEL=gpt-4o
RISK_THRESHOLD=40
HIGH_RISK_THRESHOLD=70
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=http://localhost:3000
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=false
